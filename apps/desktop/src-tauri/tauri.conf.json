{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ELB V1",
  "version": "0.1.0",
  "identifier": "ch.koller.elb-v1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ELB V1",
        "width": 1600,
        "height": 1000,
        "minWidth": 1280,
        "minHeight": 840
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
