{
  "name": "elb-v1",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "desktop:dev": "npm --workspace apps/desktop run dev",
    "desktop:tauri": "node scripts/run-tauri-dev.mjs",
    "desktop:tauri:build": "npm exec tauri build -- --config apps/desktop/src-tauri/tauri.conf.json",
    "desktop:build": "npm --workspace apps/desktop run build",
    "desktop:lint": "npm --workspace apps/desktop run lint",
    "check:encoding": "node scripts/check-mojibake.mjs",
    "test": "vitest run --passWithNoTests=false",
    "verify": "npm run check:encoding && npm run desktop:lint && npm run test && npm run desktop:build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/jszip": "^3.4.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  }
}
